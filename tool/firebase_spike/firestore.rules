rules_version = '2';
// Rules do spike Checkpoint 0 — publicar SOMENTE no projeto dev.
// Nunca usar Firestore em modo teste público.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /spike_checkpoint0/{userId}/runs/{runId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }
  }
}
